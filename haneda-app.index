<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>羽田クロノゲート専用バース着け番号検索</title>
<style>
  body { font-family: sans-serif; padding: 20px; }
  h2 { margin-bottom: 20px; }
  input, button { font-size: 18px; padding: 10px; margin: 5px 0; width: 100%; }
  .result { margin-top: 20px; font-size: 18px; }
  .box { border: 1px solid #ccc; padding: 15px; border-radius: 10px; }

  .suggestions {
    border: 1px solid #ccc;
    border-radius: 10px;
    max-height: 150px;
    overflow-y: auto;
    margin-top: 5px;
  }

  .suggestion-item {
    padding: 10px;
    cursor: pointer;
    border-bottom: 1px solid #eee;
  }

  .suggestion-item:hover {
    background-color: #f0f0f0;
  }
</style>
</head>

<body>

<h2>🚚 羽田クロノゲート専用バース着け番号検索</h2>

<input type="text" id="destination" placeholder="行き先を入力（例：中根）" oninput="showSuggestions()">
<div id="suggestions" class="suggestions"></div>

<button onclick="search()">検索</button>

<div class="result box" id="output">ここに結果が表示されます</div>

<script>
const data = {
  "神宮前２丁目": {
    berth: "17番バース",
    info: ""
  },
  "馬事公苑": {
    berth: "32番バース",
    info: ""
  },
  "中根": {
    berth: "74番バース",
    info: "南側で卸す場合はその場で積める場合があるのでヤマトのスタッフに確認してください"
  },
  "八幡山": {
    berth: "33番バース",
    info: ""
  }
};

// 候補表示
function showSuggestions() {
  let input = document.getElementById("destination").value.trim();
  let suggestionsDiv = document.getElementById("suggestions");

  suggestionsDiv.innerHTML = "";

  if (input === "") return;

  let matches = Object.keys(data).filter(key => key.includes(input));

  matches.forEach(match => {
    let div = document.createElement("div");
    div.className = "suggestion-item";
    div.innerText = match;

    div.onclick = () => {
      document.getElementById("destination").value = match;
      suggestionsDiv.innerHTML = "";
      search();
    };

    suggestionsDiv.appendChild(div);
  });
}

// 検索
function search() {
  let input = document.getElementById("destination").value.trim();
  let result = document.getElementById("output");

  if (data[input]) {
    let berth = data[input].berth;
    let info = data[input].info;

    result.innerHTML = `
      <strong>行き先：</strong> ${input}<br>
      <strong>バース：</strong> ${berth}<br>
      ${info ? "<strong>補足：</strong> " + info : ""}
    `;
  } else {
    result.innerHTML = "該当データなし";
  }
}
</script>

</body>
</html>
